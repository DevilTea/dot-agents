# ── Pi runtime state (auto-generated, not config) ───────────────────────

# Session history log — regenerated from sessions/
run-history.jsonl

# ── Per-session data ──────────────────────────────────────────────────

# Session directories (auto-created from cwd path)
agent/sessions/

# Subagent artifacts shared across sessions
agent/sessions/subagent-artifacts/

# ── Package-installed files ───────────────────────────────────────────

# npm/git package binaries & entry points
agent/bin/

# Git submodule clones of git: packages + their node_modules
agent/git/

# Fuzzy file finder databases (frecency, history) — regenerated on use
agent/pi-fff/

# Context pruning data (auto-generated by pi-core)
agent/context-prune/
